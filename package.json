{
  "name": "daily-meal",
  "private": true,
  "version": "0.1.0",
  "description": "Daily Meal mobile app and API monorepo.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm --workspace client run start",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace server run build",
    "build:apk": "npm --workspace client run build:apk",
    "build:apk:clean": "npm --workspace client run build:apk:clean",
    "build:apk:local": "npm --workspace client run build:apk:local",
    "build:apk:local:clean": "npm --workspace client run build:apk:local:clean",
    "build:aab": "npm --workspace client run build:aab",
    "build:aab:clean": "npm --workspace client run build:aab:clean",
    "typecheck": "npm --workspace server run typecheck && npm --workspace client run typecheck",
    "test": "npm --workspace server run test",
    "measurement:scan": "node scripts/scan-mojibake.mjs",
    "measurement:test": "node scripts/test-mojibake-scanner.mjs",
    "measurement:report": "node scripts/generate-measurement-report.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@react-native/virtualized-lists": "0.81.5",
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react-native": "0.81.5",
    "@react-native/virtualized-lists": "0.81.5"
  }
}
