# Public OAuth IDs. These are safe to expose in Expo public env.
EXPO_PUBLIC_FACEBOOK_APP_ID=3483710358450589
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com

# Production/preview APK default. Standalone user builds should use HTTPS.
EXPO_PUBLIC_API_URL=https://api.dailymeal.site

# Local development overrides:
# - Expo web on the same machine:
#   EXPO_PUBLIC_API_URL=http://localhost:4000
# - Android emulator debug/dev build:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
# - Physical Android debug/dev build on the same Wi-Fi:
#   EXPO_PUBLIC_API_URL=http://<your-computer-lan-ip>:4000
