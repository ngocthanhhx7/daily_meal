NODE_ENV=development
PORT=4000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/daily_meal?retryWrites=true&w=majority&appName=<appName>
# If local DNS blocks mongodb+srv, use the non-SRV Atlas URI from MongoDB Atlas > Connect > Drivers instead.
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=*
UPLOAD_DIR=uploads
STORAGE_DRIVER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Set STORAGE_DRIVER=s3 to store user uploads in Amazon S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_OBJECT_ACL=public-read
