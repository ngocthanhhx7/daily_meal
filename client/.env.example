# Facebook App ID for OAuth Login
EXPO_PUBLIC_FACEBOOK_APP_ID=3483710358450589

# API base URL for local development. Use http://localhost:4000 for Expo web,
# and http://10.0.2.2:4000 for Android emulator.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google Client IDs for OAuth Login
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
