{
  "expo": {
    "name": "Daily Meal",
    "slug": "daily-meal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dailymeal",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo/logo-square.png",
    "splash": {
      "image": "./assets/logo/logo-square.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F3EF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dailymeal.app",
      "icon": "./assets/logo/logo.png",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSMicrophoneUsageDescription": "Daily Meal needs microphone access to record short food videos."
      }
    },
    "android": {
      "package": "com.dailymeal.app",
      "versionCode": 1,
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/logo-square.png",
        "backgroundColor": "#F4F3EF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.20654020356-nsqam5ladrg7j5v6agefq8pucnrcqtn8"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Daily Meal needs photo access to create posts and analyze meals.",
          "cameraPermission": "Daily Meal needs camera access to capture meals and short videos.",
          "microphonePermission": "Daily Meal needs microphone access to record short videos."
        }
      ],
      "expo-camera"
    ],
    "extra": {
      "apiUrl": "https://api.dailymeal.site",
      "eas": {
        "projectId": "36df33dd-58ed-4c75-add9-87130fb0e12f"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/favicon.png"
    }
  }
}
