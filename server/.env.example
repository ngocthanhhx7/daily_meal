NODE_ENV=development
PORT=4000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/daily_meal?retryWrites=true&w=majority&appName=<appName>
# If local DNS blocks mongodb+srv, use the non-SRV Atlas URI from MongoDB Atlas > Connect > Drivers instead.
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=*
UPLOAD_DIR=uploads
STORAGE_DRIVER=local
# Gemini AI integration for meal photo nutrition analysis and admin reports.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-3.1-flash-lite
AI_MAX_TOKENS=1200
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Gmail SMTP email sending for password reset.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Daily Meal
MAIL_FROM_EMAIL=

# PayOS payment integration. Keep these server-side only.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=
PAYOS_API_BASE_URL=https://api-merchant.payos.vn

# Set STORAGE_DRIVER=s3 to store user uploads in Amazon S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_OBJECT_ACL=public-read

ADMIN_EMAIL=your-username@domain.local
ADMIN_PASSWORD=your-password
