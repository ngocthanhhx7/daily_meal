{
  "expo": {
    "name": "Daily Meal",
    "slug": "daily-meal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dailymeal",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dailymeal.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.dailymeal.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#F4F3EF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Daily Meal needs photo access to create posts and analyze meals.",
          "cameraPermission": "Daily Meal needs camera access to capture meals."
        }
      ],
      "expo-camera"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000",
      "eas": {
        "projectId": "36df33dd-58ed-4c75-add9-87130fb0e12f"
      }
    }
  }
}
